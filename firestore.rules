rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read and update the global metrics
    match /metrics/global {
      allow read: if true;
      allow create, update: if true;
    }
    
    // Allow anyone to read ratings and submit new ones
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false; // prevent editing or deleting reviews
    }

    // Allow anyone to read reviews and submit new ones
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false; // prevent editing or deleting reviews
    }
  }
}
